{
  "name": "sol-checker",
  "version": "0.1.0",
  "description": "Solidity smart contract vulnerability checker powered by LLM",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sol-checker": "./dist/index.js"
  },
  "files": [
    "dist/",
    "prompts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs'); const f='dist/index.js'; const c=fs.readFileSync(f,'utf8'); if(!c.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "solidity",
    "security",
    "audit",
    "llm",
    "cli"
  ],
  "author": "Masaki TSUDA",
  "repository": {
    "type": "git",
    "url": "https://github.com/masaky/sol-checker.git"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "toml": "^3.0.0"
  }
}
